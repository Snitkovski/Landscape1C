# Папка для ручной выгрузки на хостинг
/dist/

# OS
.DS_Store

# Claude Code: скиллы публикуем (глобальный gitignore прячет .claude/ — отменяем),
# локальные настройки — нет
!.claude/
.claude/settings.local.json

# Python-кэш локального сервера
__pycache__/

# Статические страницы карточек — генерит scripts/sitegen.js при сборке
app/tools/

# Бот-опросник: собранные ответы, состояние сессий и кэш телеграма
# (пререндеренные логотипы bot/logos-png/ наоборот коммитятся)
bot/answers.jsonl
bot/state.json
bot/file-ids.json
# Агрегат волны для витрины — генерит bot/aggregate.js. Тестовая волна
# публикуется как /test_survey (агрегаты без ПДн), поэтому файл в репозитории.
# Ранбук волны с адресом сервера — локальный, копия на сервере в /root
bot/RUNBOOK.local.md
